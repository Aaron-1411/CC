{
  "name": "signaldesk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Single-user Discord trading-signal journal: ingest signals, chart proposed levels, log personal execution vs. the signal.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --d1 DB --compatibility-date=2024-11-27",
    "d1:init": "wrangler d1 execute signaldesk --local --file=./schema.sql"
  },
  "dependencies": {
    "lightweight-charts": "^4.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^3.90.0"
  }
}
