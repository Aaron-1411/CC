# ─────────────────────────────────────────────────────────────────────────────
# MTD Filing Companion — HMRC sandbox configuration
#
# Copy this file to `.dev.vars` (for `wrangler pages dev` / Pages Functions local)
# and fill in the values from the HMRC Developer Hub once the app is registered.
# `.dev.vars` and `.env*` are gitignored — never commit real credentials.
#
# To obtain these:
#   1. Register the app at https://developer.service.hmrc.gov.uk (needs a
#      Government Gateway login — this is the external gate only Aaron can pass).
#   2. Create a sandbox application; copy its client ID/secret below.
#   3. Subscribe the sandbox app to "Test Fraud Prevention Headers API".
# ─────────────────────────────────────────────────────────────────────────────

# HMRC API base URLs (sandbox shown; swap to production at go-live)
HMRC_API_BASE_URL=https://test-api.service.hmrc.gov.uk
HMRC_OAUTH_BASE_URL=https://test-api.service.hmrc.gov.uk

# OAuth 2.0 client credentials (one app, used for BOTH grant types):
#  - application-restricted (client_credentials) → Test Fraud Prevention Headers
#  - user-restricted (authorization_code + refresh) → the live MTD ITSA APIs
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=

# User-restricted OAuth (3-legged) — the authorise/callback/ping routes.
# HMRC_SCOPE: space-separated scopes to request. Default if unset:
#   "read:self-assessment write:self-assessment"
HMRC_SCOPE=read:self-assessment write:self-assessment
# HMRC_REDIRECT_URI: must byte-match a redirect URI registered on the Developer
# Hub. Leave blank for local dev to derive <origin>/api/hmrc/callback from the
# request; set explicitly for preview/production.
HMRC_REDIRECT_URI=
# HMRC_PING_PATH: user-restricted smoke endpoint the /api/hmrc/ping route hits.
# Default if unset: /hello/user
HMRC_PING_PATH=/hello/user

# Vendor identity sent in Gov-Vendor-* fraud-prevention headers
GOV_VENDOR_PRODUCT_NAME=MTD Filing Companion
GOV_VENDOR_VERSION=mtd-filing-companion=0.0.0

# AES-GCM key (base64, 32 bytes) for encrypting stored HMRC refresh tokens.
# Generate with:  openssl rand -base64 32
# Not used by the Phase 0a header spike, but reserved for the HMRC client module.
TOKEN_ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase — durable storage for the (already-encrypted) HMRC tokens.
#
# The Pages Function reaches the hmrc_tokens table with the SERVICE-ROLE key,
# which bypasses RLS (the table is RLS deny-all, service-role-only — see
# supabase/migrations/0001_hmrc_tokens.sql). This key is server-only: it must
# live in .dev.vars / the Cloudflare dashboard and NEVER ship to the browser.
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project JWT secret (HS256). Used SERVER-SIDE ONLY to verify the
# caller's Supabase access token and extract their user id (sub claim). Find it
# in the Supabase dashboard under Settings → API → JWT Settings. Server-only.
SUPABASE_JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Browser Supabase client (frontend auth) — these go in `.env.local`, NOT here.
#
# Vite exposes any `VITE_`-prefixed var to the browser bundle, so ONLY put
# browser-safe values here. The anon (publishable) key is designed to ship to
# the client and is gated by Row-Level Security — it is NOT the service-role key
# above. Find both under Settings → API in the Supabase dashboard.
#   VITE_SUPABASE_URL      → same project URL as SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY → the anon / publishable key (public-safe)
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
